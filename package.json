{
  "name": "aural-ui",
  "version": "1.0.0",
  "description": "A modern, accessible design system with comprehensive components, utilities, and themes",
  "private": true,
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "build:css": "node scripts/build-css.js",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:e2e": "playwright test",
    "clean": "rm -rf packages/*/dist",
    "serve": "serve docs -p 3001",
    "demo:react": "cd examples/react-demo && npm run dev",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "npm run build:css && storybook build",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,css,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,css,md,json}\"",
    "type-check": "tsc --noEmit",
    "analyze:bundle": "node scripts/analyze-bundles.js",
    "prepare": "husky"
  },
  "keywords": [
    "ui",
    "design-system",
    "components",
    "css",
    "javascript",
    "react",
    "vue",
    "svelte",
    "accessibility",
    "wcag",
    "a11y",
    "ui-components",
    "white-label",
    "tokens",
    "design-tokens",
    "theme",
    "dark-mode",
    "responsive",
    "utilities",
    "tailwind-like"
  ],
  "author": "Workshop BAI Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ferology/aural-ui.git"
  },
  "homepage": "https://ferology.github.io/aural-ui/",
  "bugs": {
    "url": "https://github.com/ferology/aural-ui/issues"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@chromatic-com/storybook": "^3.2.2",
    "@storybook/addon-a11y": "^8.6.17",
    "@storybook/addon-docs": "^8.6.17",
    "@storybook/addon-essentials": "^8.6.17",
    "@storybook/addon-interactions": "^8.6.17",
    "@storybook/html": "^8.6.17",
    "@storybook/html-vite": "^8.6.17",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/browser": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "autoprefixer": "^10.4.16",
    "cssnano": "^6.0.2",
    "esbuild": "^0.19.11",
    "eslint": "^8.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "^0.11.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.58.2",
    "postcss": "^8.4.32",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.0.0",
    "postcss-nesting": "^12.0.2",
    "prettier": "^3.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "serve": "^14.2.1",
    "storybook": "^8.6.17",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^1.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,json}": [
      "prettier --write"
    ]
  }
}
